# Google Cloud Storage (for product/category images)
# Prefer setting GOOGLE_APPLICATION_CREDENTIALS to a local service-account JSON file path:
#   Windows PowerShell:
#     $env:GOOGLE_APPLICATION_CREDENTIALS="C:\path\to\service-account.json"
#     $env:GCS_BUCKET="your-bucket-name"
#
# Do NOT commit the real JSON key file to git.

GCS_BUCKET=supercanteen-images

